# ── Dependencies ────────────────────────────────────────────────
node_modules/

# ── Build output ────────────────────────────────────────────────
dist/

# ── Large data (regenerate with training scripts) ───────────────
data/parquet/
data/tokenized/
data/arabic/
data/sentences.json
data/sentences-1k.json
data/sentences-100.json

# ── Reasoning corpora (large JSONL — keep on Drive) ─────────────
reasoning/out/*.jsonl
reasoning/tokenized/*.jsonl

# ── Colab upload staging (derived data) ─────────────────────────
training/colab-upload/
training/colab-upload-fair/
training/colab-upload-ar/
training/colab-upload-en/
training/colab-upload-en.tar.gz

# ── SentencePiece binary models (large) ─────────────────────────
training/**/*.model
training/**/*.vocab

# ── Python bytecode & caches ────────────────────────────────────
__pycache__/
.pytest_cache/

# ── Generated PDFs (rebuild with `npm run pdf`) ─────────────────
docs/**/*.pdf

# ── Local planning notes (scratch & LLM chat dumps) ─────────────
